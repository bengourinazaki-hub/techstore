<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= product.name %> — تيك ستور</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family:'Cairo',sans-serif; direction:rtl; background:#0a0f1e; color:#e5e7eb; }
    .card-hover { transition:transform .25s,box-shadow .25s; }
    .card-hover:hover { transform:translateY(-6px); box-shadow:0 20px 40px rgba(0,212,255,.15); }
    .toast { position:fixed; bottom:2rem; left:50%; transform:translateX(-50%) translateY(100px); transition:transform .3s; z-index:9999; }
    .toast.show { transform:translateX(-50%) translateY(0); }
  </style>
</head>
<body class="min-h-screen">

<nav class="sticky top-0 z-50 border-b border-gray-800" style="background:rgba(6,11,20,.95)">
  <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2 text-xl font-black">⚡ تيك<span style="color:#00d4ff">ستور</span></a>
    <div class="hidden md:flex gap-6 text-sm font-semibold">
      <a href="/" class="text-gray-400 hover:text-white transition-colors">الرئيسية</a>
      <a href="/products" class="text-gray-400 hover:text-white transition-colors">المنتجات</a>
    </div>
    <a href="/cart" class="relative px-3 py-2 rounded-lg border border-gray-700 text-sm font-semibold" style="background:#111827">
      🛒
      <% if (cartCount > 0) { %>
        <span class="absolute -top-2 -right-2 bg-red-500 text-white text-xs w-5 h-5 rounded-full flex items-center justify-center font-bold"><%= cartCount %></span>
      <% } %>
    </a>
  </div>
</nav>

<div class="max-w-7xl mx-auto px-4 py-10">
  <!-- Breadcrumb -->
  <div class="flex items-center gap-2 text-sm text-gray-400 mb-8">
    <a href="/" class="hover:text-white transition-colors">الرئيسية</a>
    <span>/</span>
    <a href="/products" class="hover:text-white transition-colors">المنتجات</a>
    <span>/</span>
    <a href="/products?category=<%= product.category_slug %>" class="hover:text-white transition-colors"><%= product.category_name %></a>
    <span>/</span>
    <span class="text-white"><%= product.name %></span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-16">
    <!-- Image -->
    <div class="rounded-2xl border border-gray-700 overflow-hidden aspect-square flex items-center justify-center text-8xl" style="background:#111827">
      <% if (product.image) { %>
        <img src="/uploads/<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover"/>
      <% } else { %>
        📦
      <% } %>
    </div>

    <!-- Info -->
    <div class="flex flex-col">
      <div class="text-sm font-bold mb-2" style="color:#00d4ff">
        <%= product.category_name %> <% if (product.brand) { %>· <span class="text-gray-400"><%= product.brand %></span><% } %>
      </div>
      <h1 class="text-3xl font-black mb-4"><%= product.name %></h1>
      <div class="text-4xl font-black mb-6" style="color:#f97316">
        <%= product.price.toLocaleString('ar-DZ') %> <span class="text-2xl">دج</span>
      </div>

      <!-- Stock badge -->
      <div class="mb-6">
        <% if (product.stock === 0) { %>
          <span class="px-4 py-2 rounded-full text-sm font-bold bg-red-900/40 text-red-400">❌ نفد المخزون</span>
        <% } else if (product.stock <= 10) { %>
          <span class="px-4 py-2 rounded-full text-sm font-bold bg-orange-900/40 text-orange-400">⚠️ آخر <%= product.stock %> قطع في المخزون</span>
        <% } else { %>
          <span class="px-4 py-2 rounded-full text-sm font-bold bg-green-900/40 text-green-400">✅ متوفر في المخزون (<%= product.stock %> قطعة)</span>
        <% } %>
      </div>

      <!-- Description -->
      <% if (product.description) { %>
        <p class="text-gray-300 leading-relaxed mb-8 text-sm"><%= product.description %></p>
      <% } %>

      <!-- Add to cart -->
      <% if (product.stock > 0) { %>
        <div class="flex gap-4 items-center mb-4">
          <input type="number" id="qty" value="1" min="1" max="<%= product.stock %>"
            class="w-20 text-center px-3 py-3 rounded-xl border border-gray-700 font-bold text-lg focus:outline-none focus:border-blue-400"
            style="background:#111827;color:#e5e7eb"/>
          <button onclick="addToCartQty(<%= product.id %>)" class="flex-1 py-3 rounded-xl font-bold text-lg transition-all hover:opacity-90" style="background:#00d4ff;color:#0a0f1e">
            أضف إلى السلة 🛒
          </button>
        </div>
        <a href="/checkout" class="block text-center py-3 rounded-xl font-bold text-lg border border-gray-600 hover:border-white transition-colors">
          اشتري الآن ⚡
        </a>
      <% } else { %>
        <button disabled class="py-3 rounded-xl font-bold text-lg opacity-40 cursor-not-allowed bg-gray-700 text-gray-400">
          غير متوفر حالياً
        </button>
      <% } %>

      <!-- Features -->
      <div class="mt-8 grid grid-cols-3 gap-4">
        <div class="text-center p-3 rounded-xl border border-gray-700" style="background:#111827">
          <div class="text-2xl mb-1">💵</div>
          <div class="text-xs font-semibold text-gray-400">دفع عند الاستلام</div>
        </div>
        <div class="text-center p-3 rounded-xl border border-gray-700" style="background:#111827">
          <div class="text-2xl mb-1">🚚</div>
          <div class="text-xs font-semibold text-gray-400">توصيل لكل الولايات</div>
        </div>
        <div class="text-center p-3 rounded-xl border border-gray-700" style="background:#111827">
          <div class="text-2xl mb-1">✅</div>
          <div class="text-xs font-semibold text-gray-400">منتج أصلي مضمون</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Related Products -->
  <% if (related.length > 0) { %>
  <div>
    <h2 class="text-2xl font-black mb-6">منتجات مشابهة</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <% related.forEach(p => { %>
        <a href="/products/<%= p.id %>" class="card-hover rounded-2xl border border-gray-700 overflow-hidden block" style="background:#111827;text-decoration:none;color:inherit">
          <div class="h-36 flex items-center justify-center text-4xl" style="background:#1f2937">
            <% if (p.image) { %>
              <img src="/uploads/<%= p.image %>" alt="<%= p.name %>" class="w-full h-full object-cover"/>
            <% } else { %>📦<% } %>
          </div>
          <div class="p-3">
            <div class="font-bold text-sm mb-1"><%= p.name %></div>
            <div class="font-black text-sm" style="color:#f97316"><%= p.price.toLocaleString('ar-DZ') %> دج</div>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
  <% } %>
</div>

<footer class="border-t border-gray-800 mt-16 py-8 px-4 text-center text-gray-600 text-sm" style="background:#060b14">
  © 2026 تيك ستور — جميع الحقوق محفوظة
</footer>

<div class="toast" id="toast">
  <div class="bg-green-600 text-white px-6 py-3 rounded-full font-semibold shadow-xl text-sm" id="toastMsg"></div>
</div>

<script src="/js/cart.js"></script>
<script>
function addToCartQty(id) {
  const qty = document.getElementById('qty').value;
  fetch('/cart/add', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ product_id: id, quantity: parseInt(qty) })
  })
  .then(r => r.json())
  .then(data => {
    if (data.success) showToast(data.message);
    else showToast(data.message, true);
  });
}
</script>
</body>
</html>
