<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>تفاصيل الطلب #<%= String(order.id).padStart(5,'0') %> — تيك ستور</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>body { font-family:'Cairo',sans-serif; direction:rtl; }</style>
</head>
<body class="bg-gray-100 min-h-screen flex">

<!-- SIDEBAR -->
<aside class="w-64 bg-blue-800 min-h-screen flex flex-col p-4 fixed right-0 top-0 bottom-0 z-40">
  <a href="/admin/dashboard" class="flex items-center gap-2 text-white text-xl font-black mb-8 px-2">⚡ تيك<span class="text-blue-200">ستور</span></a>
  <nav class="flex flex-col gap-1 flex-1">
    <a href="/admin/dashboard" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-blue-200 hover:bg-white/10 hover:text-white transition-colors">📊 لوحة التحكم</a>
    <a href="/admin/products" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-blue-200 hover:bg-white/10 hover:text-white transition-colors">📦 المنتجات</a>
    <a href="/admin/orders" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm bg-white/10 text-white">🛒 الطلبات</a>
    <a href="/admin/categories" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-blue-200 hover:bg-white/10 hover:text-white transition-colors">🏷️ الفئات</a>
    <div class="mt-auto pt-4 border-t border-blue-700">
      <a href="/" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-blue-200 hover:bg-white/10 transition-colors">🏠 الموقع</a>
      <a href="/admin/logout" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-red-300 hover:bg-white/10 transition-colors">🚪 تسجيل الخروج</a>
    </div>
  </nav>
</aside>

<main class="flex-1 mr-64 p-6">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-black text-gray-800">طلب #<%= String(order.id).padStart(5,'0') %></h1>
      <p class="text-gray-400 text-sm mt-1"><%= new Date(order.created_at).toLocaleString('ar-DZ') %></p>
    </div>
    <a href="/admin/orders" class="px-4 py-2 rounded-xl font-bold text-sm border border-gray-300 text-gray-600 hover:bg-gray-50 transition-colors">← العودة للطلبات</a>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Customer Info -->
    <div class="lg:col-span-2 space-y-6">
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
        <h2 class="font-black text-gray-800 mb-4">👤 معلومات العميل</h2>
        <div class="grid grid-cols-2 gap-4 text-sm">
          <div class="p-3 rounded-xl bg-gray-50">
            <div class="text-gray-400 text-xs mb-1">الاسم</div>
            <div class="font-bold"><%= order.first_name %></div>
          </div>
          <div class="p-3 rounded-xl bg-gray-50">
            <div class="text-gray-400 text-xs mb-1">اللقب</div>
            <div class="font-bold"><%= order.last_name %></div>
          </div>
          <div class="p-3 rounded-xl bg-gray-50">
            <div class="text-gray-400 text-xs mb-1">رقم الهاتف</div>
            <div class="font-bold text-blue-600"><%= order.phone %></div>
          </div>
          <div class="p-3 rounded-xl bg-gray-50">
            <div class="text-gray-400 text-xs mb-1">البريد الإلكتروني</div>
            <div class="font-bold"><%= order.email || '—' %></div>
          </div>
          <div class="p-3 rounded-xl bg-gray-50">
            <div class="text-gray-400 text-xs mb-1">الولاية</div>
            <div class="font-bold"><%= order.wilaya %></div>
          </div>
          <div class="p-3 rounded-xl bg-gray-50 col-span-2">
            <div class="text-gray-400 text-xs mb-1">العنوان التفصيلي</div>
            <div class="font-bold"><%= order.address %></div>
          </div>
          <% if (order.notes) { %>
          <div class="p-3 rounded-xl bg-yellow-50 border border-yellow-200 col-span-2">
            <div class="text-yellow-600 text-xs mb-1 font-bold">ملاحظات العميل</div>
            <div class="font-semibold text-gray-700"><%= order.notes %></div>
          </div>
          <% } %>
        </div>
      </div>

      <!-- Order Items -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="p-5 border-b border-gray-100">
          <h2 class="font-black text-gray-800">📦 المنتجات المطلوبة</h2>
        </div>
        <table class="w-full text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="text-right px-4 py-3 font-bold text-gray-600">المنتج</th>
              <th class="text-right px-4 py-3 font-bold text-gray-600">سعر الوحدة</th>
              <th class="text-right px-4 py-3 font-bold text-gray-600">الكمية</th>
              <th class="text-right px-4 py-3 font-bold text-gray-600">المجموع</th>
            </tr>
          </thead>
          <tbody>
            <% items.forEach(item => { %>
            <tr class="border-t border-gray-50">
              <td class="px-4 py-3">
                <div class="flex items-center gap-3">
                  <div class="w-12 h-12 rounded-lg flex items-center justify-center text-xl bg-gray-100 flex-shrink-0">
                    <% if (item.product_image) { %>
                      <img src="/uploads/<%= item.product_image %>" alt="<%= item.product_name %>" class="w-full h-full object-cover rounded-lg"/>
                    <% } else { %>📦<% } %>
                  </div>
                  <span class="font-semibold"><%= item.product_name %></span>
                </div>
              </td>
              <td class="px-4 py-3 text-gray-600"><%= item.unit_price.toLocaleString('ar-DZ') %> دج</td>
              <td class="px-4 py-3 font-bold text-center"><%= item.quantity %></td>
              <td class="px-4 py-3 font-black text-orange-600"><%= (item.unit_price * item.quantity).toLocaleString('ar-DZ') %> دج</td>
            </tr>
            <% }) %>
            <tr class="border-t-2 border-gray-200 bg-gray-50">
              <td colspan="3" class="px-4 py-3 font-black text-gray-800 text-left">المجموع الكلي</td>
              <td class="px-4 py-3 font-black text-2xl text-orange-600"><%= order.total.toLocaleString('ar-DZ') %> دج</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Status Update -->
    <div class="space-y-4">
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
        <h2 class="font-black text-gray-800 mb-4">📋 حالة الطلب</h2>
        <%
          const statusMap = {pending:'قيد الانتظار',confirmed:'تم التأكيد',shipped:'قيد الشحن',delivered:'تم التسليم',cancelled:'ملغي'};
          const colorMap = {pending:'bg-yellow-100 text-yellow-700',confirmed:'bg-blue-100 text-blue-700',shipped:'bg-purple-100 text-purple-700',delivered:'bg-green-100 text-green-700',cancelled:'bg-red-100 text-red-700'};
        %>
        <div class="mb-4">
          <span class="px-3 py-2 rounded-xl text-sm font-black <%= colorMap[order.status] || 'bg-gray-100 text-gray-600' %>">
            <%= statusMap[order.status] || order.status %>
          </span>
        </div>
        <form method="POST" action="/admin/orders/<%= order.id %>/status">
          <label class="block text-sm font-bold text-gray-700 mb-2">تغيير الحالة</label>
          <select name="status" class="w-full px-3 py-2 rounded-xl border border-gray-300 text-sm font-semibold focus:outline-none focus:border-blue-400 mb-3">
            <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>⏳ قيد الانتظار</option>
            <option value="confirmed" <%= order.status === 'confirmed' ? 'selected' : '' %>>✅ تم التأكيد</option>
            <option value="shipped" <%= order.status === 'shipped' ? 'selected' : '' %>>🚚 قيد الشحن</option>
            <option value="delivered" <%= order.status === 'delivered' ? 'selected' : '' %>>📦 تم التسليم</option>
            <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>❌ ملغي</option>
          </select>
          <button type="submit" class="w-full py-2 rounded-xl font-bold text-sm text-white transition-all hover:opacity-90" style="background:#3b82f6">
            تحديث الحالة
          </button>
        </form>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
        <h2 class="font-black text-gray-800 mb-3">💵 طريقة الدفع</h2>
        <div class="flex items-center gap-2 text-green-600 font-bold">
          <span class="text-2xl">💵</span> الدفع عند الاستلام
        </div>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
        <h2 class="font-black text-gray-800 mb-3">📅 تاريخ الطلب</h2>
        <p class="text-gray-600 text-sm font-semibold"><%= new Date(order.created_at).toLocaleString('ar-DZ') %></p>
      </div>
    </div>
  </div>
</main>
</body>
</html>
