<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>لوحة التحكم — تيك ستور</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>body { font-family:'Cairo',sans-serif; direction:rtl; }</style>
</head>
<body class="bg-gray-100 min-h-screen flex">

<!-- SIDEBAR -->
<aside class="w-64 bg-blue-800 min-h-screen flex flex-col p-4 fixed right-0 top-0 bottom-0 z-40">
  <a href="/admin/dashboard" class="flex items-center gap-2 text-white text-xl font-black mb-8 px-2">
    <span>⚡</span> تيك<span class="text-blue-200">ستور</span>
  </a>
  <nav class="flex flex-col gap-1 flex-1">
    <a href="/admin/dashboard" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm bg-white/10 text-white">📊 لوحة التحكم</a>
    <a href="/admin/products" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-blue-200 hover:bg-white/10 hover:text-white transition-colors">📦 المنتجات</a>
    <a href="/admin/orders" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-blue-200 hover:bg-white/10 hover:text-white transition-colors">
      🛒 الطلبات
      <% if (newOrdersCount > 0) { %><span class="mr-auto bg-red-500 text-white text-xs px-2 py-0.5 rounded-full"><%= newOrdersCount %></span><% } %>
    </a>
    <a href="/admin/categories" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-blue-200 hover:bg-white/10 hover:text-white transition-colors">🏷️ الفئات</a>
    <div class="mt-auto pt-4 border-t border-blue-700">
      <a href="/" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-blue-200 hover:bg-white/10 transition-colors">🏠 الموقع</a>
      <a href="/admin/logout" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-red-300 hover:bg-white/10 transition-colors">🚪 تسجيل الخروج</a>
    </div>
  </nav>
</aside>

<main class="flex-1 mr-64 p-6">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-black text-gray-800">لوحة التحكم</h1>
    <span class="text-gray-500 text-sm">مرحباً، <%= user.name %></span>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
      <div class="text-3xl mb-2">🛒</div>
      <div class="text-3xl font-black text-gray-800"><%= totalOrders %></div>
      <div class="text-sm text-gray-500 mt-1">إجمالي الطلبات</div>
      <div class="text-xs text-blue-500 mt-1 font-semibold">اليوم: <%= todayOrders %></div>
    </div>
    <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
      <div class="text-3xl mb-2">💰</div>
      <div class="text-2xl font-black text-gray-800"><%= revenue.toLocaleString('ar-DZ') %></div>
      <div class="text-sm text-gray-500 mt-1">الإيرادات (دج)</div>
      <div class="text-xs text-green-500 mt-1 font-semibold">من الطلبات المسلّمة</div>
    </div>
    <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
      <div class="text-3xl mb-2">📦</div>
      <div class="text-3xl font-black text-gray-800"><%= totalProducts %></div>
      <div class="text-sm text-gray-500 mt-1">عدد المنتجات</div>
    </div>
    <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 <%= pendingOrders > 0 ? 'border-yellow-300 bg-yellow-50' : '' %>">
      <div class="text-3xl mb-2">⏳</div>
      <div class="text-3xl font-black <%= pendingOrders > 0 ? 'text-yellow-600' : 'text-gray-800' %>"><%= pendingOrders %></div>
      <div class="text-sm text-gray-500 mt-1">طلبات قيد الانتظار</div>
      <% if (pendingOrders > 0) { %><div class="text-xs text-yellow-600 mt-1 font-semibold">تحتاج مراجعة!</div><% } %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Recent Orders -->
    <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="flex items-center justify-between p-5 border-b border-gray-100">
        <h2 class="font-black text-gray-800">آخر الطلبات</h2>
        <a href="/admin/orders" class="text-blue-600 text-sm font-semibold hover:underline">عرض الكل</a>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="text-right px-4 py-3 font-bold text-gray-600">#</th>
              <th class="text-right px-4 py-3 font-bold text-gray-600">العميل</th>
              <th class="text-right px-4 py-3 font-bold text-gray-600">الولاية</th>
              <th class="text-right px-4 py-3 font-bold text-gray-600">المجموع</th>
              <th class="text-right px-4 py-3 font-bold text-gray-600">الحالة</th>
            </tr>
          </thead>
          <tbody>
            <% if (recentOrders.length === 0) { %>
              <tr><td colspan="5" class="text-center py-8 text-gray-400">لا توجد طلبات بعد</td></tr>
            <% } %>
            <% recentOrders.forEach(o => { %>
            <tr class="border-t border-gray-50 hover:bg-gray-50 transition-colors">
              <td class="px-4 py-3 font-bold text-gray-500">#<%= String(o.id).padStart(5,'0') %></td>
              <td class="px-4 py-3 font-semibold"><%= o.first_name %> <%= o.last_name %></td>
              <td class="px-4 py-3 text-gray-500 text-xs"><%= o.wilaya.split(' - ')[1] || o.wilaya %></td>
              <td class="px-4 py-3 font-black text-orange-600"><%= o.total.toLocaleString('ar-DZ') %> دج</td>
              <td class="px-4 py-3">
                <% const statusMap = {pending:'قيد الانتظار',confirmed:'تم التأكيد',shipped:'قيد الشحن',delivered:'تم التسليم',cancelled:'ملغي'}; %>
                <% const colorMap = {pending:'bg-yellow-100 text-yellow-700',confirmed:'bg-blue-100 text-blue-700',shipped:'bg-purple-100 text-purple-700',delivered:'bg-green-100 text-green-700',cancelled:'bg-red-100 text-red-700'}; %>
                <span class="px-2 py-1 rounded-full text-xs font-bold <%= colorMap[o.status] || 'bg-gray-100 text-gray-600' %>">
                  <%= statusMap[o.status] || o.status %>
                </span>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Low Stock -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="flex items-center justify-between p-5 border-b border-gray-100">
        <h2 class="font-black text-gray-800">⚠️ مخزون منخفض</h2>
        <a href="/admin/products" class="text-blue-600 text-sm font-semibold hover:underline">إدارة</a>
      </div>
      <div class="p-4 space-y-3">
        <% if (lowStock.length === 0) { %>
          <p class="text-gray-400 text-sm text-center py-4">✅ المخزون بخير</p>
        <% } %>
        <% lowStock.forEach(p => { %>
          <div class="flex items-center justify-between p-3 rounded-xl bg-gray-50">
            <span class="text-sm font-semibold text-gray-700 truncate ml-2"><%= p.name %></span>
            <span class="text-xs font-black px-2 py-1 rounded-full flex-shrink-0 <%= p.stock === 0 ? 'bg-red-100 text-red-600' : 'bg-orange-100 text-orange-600' %>">
              <%= p.stock === 0 ? 'نفد' : p.stock + ' قطع' %>
            </span>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</main>
</body>
</html>
