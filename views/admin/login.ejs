<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>تسجيل دخول الإدارة — تيك ستور</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>body { font-family:'Cairo',sans-serif; direction:rtl; background:#0f172a; color:#e5e7eb; }</style>
</head>
<body class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <div class="text-5xl mb-3">⚡</div>
      <h1 class="text-3xl font-black">تيك<span style="color:#3b82f6">ستور</span></h1>
      <p class="text-gray-400 mt-2">لوحة تحكم الإدارة</p>
    </div>

    <div class="rounded-2xl border border-gray-700 p-8" style="background:#1e293b">
      <h2 class="text-xl font-black mb-6">تسجيل الدخول</h2>

      <% if (error) { %>
        <div class="mb-4 p-3 rounded-xl border border-red-700 bg-red-900/20 text-red-400 text-sm font-semibold">
          ⚠️ <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/admin/login" class="space-y-4">
        <div>
          <label class="block text-sm font-bold text-gray-300 mb-2">البريد الإلكتروني</label>
          <input type="email" name="email" placeholder="admin@admin.com" required
            class="w-full px-4 py-3 rounded-xl border border-gray-600 text-sm font-semibold focus:outline-none focus:border-blue-400 transition-colors"
            style="background:#0f172a;color:#e5e7eb"/>
        </div>
        <div>
          <label class="block text-sm font-bold text-gray-300 mb-2">كلمة المرور</label>
          <input type="password" name="password" placeholder="••••••••" required
            class="w-full px-4 py-3 rounded-xl border border-gray-600 text-sm font-semibold focus:outline-none focus:border-blue-400 transition-colors"
            style="background:#0f172a;color:#e5e7eb"/>
        </div>
        <button type="submit" class="w-full py-3 rounded-xl font-black text-lg transition-all hover:opacity-90 mt-2" style="background:#3b82f6;color:#fff">
          دخول ←
        </button>
      </form>

      <div class="mt-6 p-3 rounded-xl text-xs text-gray-500 text-center border border-gray-700" style="background:#0f172a">
        admin@admin.com / Admin@123
      </div>
    </div>

    <p class="text-center mt-6 text-sm text-gray-500">
      <a href="/" class="hover:text-white transition-colors">← العودة للموقع</a>
    </p>
  </div>
</body>
</html>
