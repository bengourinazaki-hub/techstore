<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>إدارة الفئات — تيك ستور</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>body { font-family:'Cairo',sans-serif; direction:rtl; }</style>
</head>
<body class="bg-gray-100 min-h-screen flex">

<!-- SIDEBAR -->
<aside class="w-64 bg-blue-800 min-h-screen flex flex-col p-4 fixed right-0 top-0 bottom-0 z-40">
  <a href="/admin/dashboard" class="flex items-center gap-2 text-white text-xl font-black mb-8 px-2">⚡ تيك<span class="text-blue-200">ستور</span></a>
  <nav class="flex flex-col gap-1 flex-1">
    <a href="/admin/dashboard" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-blue-200 hover:bg-white/10 hover:text-white transition-colors">📊 لوحة التحكم</a>
    <a href="/admin/products" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-blue-200 hover:bg-white/10 hover:text-white transition-colors">📦 المنتجات</a>
    <a href="/admin/orders" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-blue-200 hover:bg-white/10 hover:text-white transition-colors">
      🛒 الطلبات
      <% if (newOrdersCount > 0) { %><span class="mr-auto bg-red-500 text-white text-xs px-2 py-0.5 rounded-full"><%= newOrdersCount %></span><% } %>
    </a>
    <a href="/admin/categories" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm bg-white/10 text-white">🏷️ الفئات</a>
    <div class="mt-auto pt-4 border-t border-blue-700">
      <a href="/" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-blue-200 hover:bg-white/10 transition-colors">🏠 الموقع</a>
      <a href="/admin/logout" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-red-300 hover:bg-white/10 transition-colors">🚪 تسجيل الخروج</a>
    </div>
  </nav>
</aside>

<main class="flex-1 mr-64 p-6">
  <h1 class="text-2xl font-black text-gray-800 mb-6">إدارة الفئات</h1>

  <% if (success) { %>
    <div class="mb-4 p-3 rounded-xl border border-green-300 bg-green-50 text-green-700 text-sm font-semibold">✅ <%= success %></div>
  <% } %>
  <% if (error) { %>
    <div class="mb-4 p-3 rounded-xl border border-red-300 bg-red-50 text-red-700 text-sm font-semibold">⚠️ <%= error %></div>
  <% } %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Add Category Form -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 h-fit">
      <h2 class="font-black text-gray-800 mb-4">➕ إضافة فئة جديدة</h2>
      <form method="POST" action="/admin/categories" class="space-y-4">
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">اسم الفئة (بالعربية) <span class="text-red-500">*</span></label>
          <input type="text" name="name" required placeholder="مثال: هواتف ذكية"
            class="w-full px-4 py-3 rounded-xl border border-gray-300 text-sm font-semibold focus:outline-none focus:border-blue-400 transition-colors"/>
        </div>
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">الاسم المختصر (slug) <span class="text-red-500">*</span></label>
          <input type="text" name="slug" required placeholder="مثال: phones" dir="ltr"
            class="w-full px-4 py-3 rounded-xl border border-gray-300 text-sm font-semibold focus:outline-none focus:border-blue-400 transition-colors"/>
          <p class="text-xs text-gray-400 mt-1">أحرف إنجليزية صغيرة وشرطات فقط</p>
        </div>
        <button type="submit" class="w-full py-3 rounded-xl font-black text-white transition-all hover:opacity-90" style="background:#3b82f6">
          إضافة الفئة
        </button>
      </form>
    </div>

    <!-- Categories List -->
    <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="p-5 border-b border-gray-100">
        <h2 class="font-black text-gray-800">الفئات الحالية (<%= categories.length %>)</h2>
      </div>
      <% if (categories.length === 0) { %>
        <div class="text-center py-12 text-gray-400">لا توجد فئات بعد</div>
      <% } else { %>
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-100">
          <tr>
            <th class="text-right px-4 py-3 font-bold text-gray-600">#</th>
            <th class="text-right px-4 py-3 font-bold text-gray-600">اسم الفئة</th>
            <th class="text-right px-4 py-3 font-bold text-gray-600">الاسم المختصر</th>
            <th class="text-right px-4 py-3 font-bold text-gray-600">عدد المنتجات</th>
            <th class="text-right px-4 py-3 font-bold text-gray-600">حذف</th>
          </tr>
        </thead>
        <tbody>
          <% categories.forEach(c => { %>
          <tr class="border-t border-gray-50 hover:bg-gray-50 transition-colors">
            <td class="px-4 py-3 text-gray-400 font-semibold"><%= c.id %></td>
            <td class="px-4 py-3 font-bold text-gray-800"><%= c.name %></td>
            <td class="px-4 py-3 font-mono text-xs text-gray-500 bg-gray-50 rounded" dir="ltr"><%= c.slug %></td>
            <td class="px-4 py-3">
              <span class="px-2 py-1 rounded-full text-xs font-bold bg-blue-100 text-blue-700"><%= c.product_count %> منتج</span>
            </td>
            <td class="px-4 py-3">
              <form method="POST" action="/admin/categories/<%= c.id %>/delete" onsubmit="return confirm('هل أنت متأكد؟ سيتم إلغاء ربط <%= c.product_count %> منتج بهذه الفئة.')">
                <button type="submit" class="px-3 py-1 rounded-lg text-xs font-bold bg-red-100 text-red-600 hover:bg-red-200 transition-colors">حذف</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>
</main>
</body>
</html>
