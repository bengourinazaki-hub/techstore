<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>إدارة الطلبات — تيك ستور</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>body { font-family:'Cairo',sans-serif; direction:rtl; }</style>
</head>
<body class="bg-gray-100 min-h-screen flex">

<!-- SIDEBAR -->
<aside class="w-64 bg-blue-800 min-h-screen flex flex-col p-4 fixed right-0 top-0 bottom-0 z-40">
  <a href="/admin/dashboard" class="flex items-center gap-2 text-white text-xl font-black mb-8 px-2">⚡ تيك<span class="text-blue-200">ستور</span></a>
  <nav class="flex flex-col gap-1 flex-1">
    <a href="/admin/dashboard" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-blue-200 hover:bg-white/10 hover:text-white transition-colors">📊 لوحة التحكم</a>
    <a href="/admin/products" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-blue-200 hover:bg-white/10 hover:text-white transition-colors">📦 المنتجات</a>
    <a href="/admin/orders" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm bg-white/10 text-white">🛒 الطلبات</a>
    <a href="/admin/categories" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-blue-200 hover:bg-white/10 hover:text-white transition-colors">🏷️ الفئات</a>
    <div class="mt-auto pt-4 border-t border-blue-700">
      <a href="/" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-blue-200 hover:bg-white/10 transition-colors">🏠 الموقع</a>
      <a href="/admin/logout" class="flex items-center gap-2 px-3 py-2 rounded-lg font-semibold text-sm text-red-300 hover:bg-white/10 transition-colors">🚪 تسجيل الخروج</a>
    </div>
  </nav>
</aside>

<main class="flex-1 mr-64 p-6">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-black text-gray-800">إدارة الطلبات</h1>
    <span class="text-gray-500 text-sm"><%= orders.length %> طلب</span>
  </div>

  <!-- Filters -->
  <form method="GET" action="/admin/orders" class="flex gap-3 flex-wrap mb-6">
    <select name="status" class="px-4 py-2 rounded-xl border border-gray-300 text-sm font-semibold focus:outline-none bg-white">
      <option value="">كل الحالات</option>
      <option value="pending" <%= status === 'pending' ? 'selected' : '' %>>قيد الانتظار</option>
      <option value="confirmed" <%= status === 'confirmed' ? 'selected' : '' %>>تم التأكيد</option>
      <option value="shipped" <%= status === 'shipped' ? 'selected' : '' %>>قيد الشحن</option>
      <option value="delivered" <%= status === 'delivered' ? 'selected' : '' %>>تم التسليم</option>
      <option value="cancelled" <%= status === 'cancelled' ? 'selected' : '' %>>ملغي</option>
    </select>
    <input type="text" name="wilaya" value="<%= wilaya %>" placeholder="فلتر بالولاية..."
      class="px-4 py-2 rounded-xl border border-gray-300 text-sm font-semibold focus:outline-none bg-white w-48"/>
    <button type="submit" class="px-5 py-2 rounded-xl font-bold text-sm text-white" style="background:#3b82f6">تطبيق</button>
    <% if (status || wilaya) { %>
      <a href="/admin/orders" class="px-4 py-2 rounded-xl font-bold text-sm border border-gray-300 text-gray-600 hover:bg-gray-50 transition-colors">مسح</a>
    <% } %>
  </form>

  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-100">
          <tr>
            <th class="text-right px-4 py-3 font-bold text-gray-600">رقم الطلب</th>
            <th class="text-right px-4 py-3 font-bold text-gray-600">الاسم الكامل</th>
            <th class="text-right px-4 py-3 font-bold text-gray-600">الهاتف</th>
            <th class="text-right px-4 py-3 font-bold text-gray-600">الولاية</th>
            <th class="text-right px-4 py-3 font-bold text-gray-600">المجموع</th>
            <th class="text-right px-4 py-3 font-bold text-gray-600">الحالة</th>
            <th class="text-right px-4 py-3 font-bold text-gray-600">التاريخ</th>
            <th class="text-right px-4 py-3 font-bold text-gray-600">تفاصيل</th>
          </tr>
        </thead>
        <tbody>
          <% if (orders.length === 0) { %>
            <tr><td colspan="8" class="text-center py-12 text-gray-400">لا توجد طلبات</td></tr>
          <% } %>
          <%
            const statusMap = {pending:'قيد الانتظار',confirmed:'تم التأكيد',shipped:'قيد الشحن',delivered:'تم التسليم',cancelled:'ملغي'};
            const colorMap = {pending:'bg-yellow-100 text-yellow-700',confirmed:'bg-blue-100 text-blue-700',shipped:'bg-purple-100 text-purple-700',delivered:'bg-green-100 text-green-700',cancelled:'bg-red-100 text-red-700'};
          %>
          <% orders.forEach(o => { %>
          <tr class="border-t border-gray-50 hover:bg-gray-50 transition-colors <%= !o.viewed ? 'bg-blue-50/50' : '' %>">
            <td class="px-4 py-3 font-black text-blue-600">
              #<%= String(o.id).padStart(5,'0') %>
              <% if (!o.viewed) { %><span class="mr-1 px-1.5 py-0.5 rounded-full text-xs font-bold bg-red-500 text-white">جديد</span><% } %>
            </td>
            <td class="px-4 py-3 font-semibold"><%= o.first_name %> <%= o.last_name %></td>
            <td class="px-4 py-3 text-gray-600"><%= o.phone %></td>
            <td class="px-4 py-3 text-gray-500 text-xs"><%= o.wilaya.split(' - ')[1] || o.wilaya %></td>
            <td class="px-4 py-3 font-black text-orange-600"><%= o.total.toLocaleString('ar-DZ') %> دج</td>
            <td class="px-4 py-3">
              <span class="px-2 py-1 rounded-full text-xs font-bold <%= colorMap[o.status] || 'bg-gray-100 text-gray-600' %>">
                <%= statusMap[o.status] || o.status %>
              </span>
            </td>
            <td class="px-4 py-3 text-gray-400 text-xs"><%= new Date(o.created_at).toLocaleDateString('ar-DZ') %></td>
            <td class="px-4 py-3">
              <a href="/admin/orders/<%= o.id %>" class="px-3 py-1 rounded-lg text-xs font-bold bg-blue-100 text-blue-700 hover:bg-blue-200 transition-colors">عرض</a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</main>
</body>
</html>
