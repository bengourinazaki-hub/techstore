<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= typeof title !== 'undefined' ? title + ' — لوحة التحكم' : 'لوحة التحكم' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: { extend: { fontFamily: { cairo: ['Cairo','sans-serif'] } } }
    }
  </script>
  <style>
    body { font-family: 'Cairo', sans-serif; direction: rtl; }
    .sidebar-link { display:flex; align-items:center; gap:.6rem; padding:.6rem 1rem; border-radius:.5rem; font-weight:600; font-size:.9rem; transition:all .2s; color:#cbd5e1; }
    .sidebar-link:hover, .sidebar-link.active { background:rgba(255,255,255,.1); color:#fff; }
  </style>
</head>
<body class="bg-gray-100 min-h-screen flex">

<!-- SIDEBAR -->
<aside class="w-64 bg-blue-800 min-h-screen flex flex-col p-4 fixed right-0 top-0 bottom-0 z-40">
  <a href="/admin/dashboard" class="flex items-center gap-2 text-white text-xl font-black mb-8 px-2">
    <span>⚡</span> تيك<span class="text-blue-200">ستور</span>
  </a>
  <nav class="flex flex-col gap-1 flex-1">
    <a href="/admin/dashboard" class="sidebar-link <%= typeof title !== 'undefined' && title.includes('لوحة') ? 'active' : '' %>">
      <span>📊</span> لوحة التحكم
    </a>
    <a href="/admin/products" class="sidebar-link <%= typeof title !== 'undefined' && title.includes('منتج') ? 'active' : '' %>">
      <span>📦</span> المنتجات
    </a>
    <a href="/admin/orders" class="sidebar-link <%= typeof title !== 'undefined' && title.includes('طلب') ? 'active' : '' %>">
      <span>🛒</span> الطلبات
      <% if (newOrdersCount > 0) { %>
        <span class="mr-auto bg-red-500 text-white text-xs px-2 py-0.5 rounded-full"><%= newOrdersCount %></span>
      <% } %>
    </a>
    <a href="/admin/categories" class="sidebar-link <%= typeof title !== 'undefined' && title.includes('فئ') ? 'active' : '' %>">
      <span>🏷️</span> الفئات
    </a>
    <div class="mt-auto pt-4 border-t border-blue-700">
      <a href="/" class="sidebar-link"><span>🏠</span> الموقع</a>
      <a href="/admin/logout" class="sidebar-link text-red-300 hover:text-red-200"><span>🚪</span> تسجيل الخروج</a>
    </div>
  </nav>
</aside>

<!-- MAIN -->
<main class="flex-1 mr-64 p-6 min-h-screen">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-black text-gray-800"><%= typeof title !== 'undefined' ? title : '' %></h1>
    <span class="text-gray-500 text-sm">مرحباً، <%= user ? user.name : 'المدير' %></span>
  </div>
  <%- body %>
</main>

</body>
</html>
