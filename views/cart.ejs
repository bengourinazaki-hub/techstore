<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>سلة التسوق — تيك ستور</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>body { font-family:'Cairo',sans-serif; direction:rtl; background:#0a0f1e; color:#e5e7eb; }</style>
</head>
<body class="min-h-screen">

<nav class="sticky top-0 z-50 border-b border-gray-800" style="background:rgba(6,11,20,.95)">
  <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2 text-xl font-black">⚡ تيك<span style="color:#00d4ff">ستور</span></a>
    <div class="hidden md:flex gap-6 text-sm font-semibold">
      <a href="/" class="text-gray-400 hover:text-white transition-colors">الرئيسية</a>
      <a href="/products" class="text-gray-400 hover:text-white transition-colors">المنتجات</a>
    </div>
    <a href="/cart" class="relative px-3 py-2 rounded-lg border border-gray-700 text-sm font-semibold" style="background:#111827;color:#00d4ff">
      🛒 <% if (cartCount > 0) { %><span class="font-black"><%= cartCount %></span><% } %>
    </a>
  </div>
</nav>

<div class="max-w-5xl mx-auto px-4 py-10">
  <h1 class="text-3xl font-black mb-8">🛒 سلة التسوق</h1>

  <% if (cart.length === 0) { %>
    <div class="text-center py-24 text-gray-400">
      <div class="text-7xl mb-6">🛒</div>
      <p class="text-2xl font-bold mb-3">سلتك فارغة</p>
      <p class="text-sm mb-8">أضف بعض المنتجات لتبدأ التسوق</p>
      <a href="/products" class="inline-block px-8 py-4 rounded-xl font-bold text-lg" style="background:#00d4ff;color:#0a0f1e">تسوق الآن</a>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Cart Items -->
      <div class="lg:col-span-2 space-y-4">
        <% cart.forEach(item => { %>
          <div class="flex gap-4 p-4 rounded-2xl border border-gray-700" style="background:#111827">
            <div class="w-20 h-20 rounded-xl flex items-center justify-center text-3xl flex-shrink-0" style="background:#1f2937">
              <% if (item.image) { %>
                <img src="/uploads/<%= item.image %>" alt="<%= item.name %>" class="w-full h-full object-cover rounded-xl"/>
              <% } else { %>📦<% } %>
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-bold mb-1 truncate"><%= item.name %></div>
              <div class="font-black text-lg" style="color:#f97316"><%= item.price.toLocaleString('ar-DZ') %> دج</div>
            </div>
            <div class="flex flex-col items-end gap-2">
              <form method="POST" action="/cart/remove">
                <input type="hidden" name="product_id" value="<%= item.id %>"/>
                <button type="submit" class="text-red-400 hover:text-red-300 text-sm font-semibold transition-colors">✕ حذف</button>
              </form>
              <form method="POST" action="/cart/update" class="flex items-center gap-2">
                <input type="hidden" name="product_id" value="<%= item.id %>"/>
                <button type="submit" name="quantity" value="<%= item.quantity - 1 %>"
                  class="w-8 h-8 rounded-lg border border-gray-600 font-bold hover:border-white transition-colors flex items-center justify-center" style="background:#1f2937">−</button>
                <span class="w-8 text-center font-bold"><%= item.quantity %></span>
                <button type="submit" name="quantity" value="<%= item.quantity + 1 %>"
                  class="w-8 h-8 rounded-lg border border-gray-600 font-bold hover:border-white transition-colors flex items-center justify-center" style="background:#1f2937">+</button>
              </form>
              <div class="text-sm font-bold text-gray-300"><%= (item.price * item.quantity).toLocaleString('ar-DZ') %> دج</div>
            </div>
          </div>
        <% }) %>
      </div>

      <!-- Summary -->
      <div class="rounded-2xl border border-gray-700 p-6 h-fit" style="background:#111827">
        <h3 class="text-lg font-black mb-4">ملخص الطلب</h3>
        <% cart.forEach(item => { %>
          <div class="flex justify-between text-sm py-2 border-b border-gray-700">
            <span class="text-gray-400 truncate ml-2"><%= item.name %> × <%= item.quantity %></span>
            <span class="font-semibold flex-shrink-0"><%= (item.price * item.quantity).toLocaleString('ar-DZ') %> دج</span>
          </div>
        <% }) %>
        <div class="flex justify-between items-center mt-4 pt-2">
          <span class="font-black text-lg">المجموع الكلي</span>
          <span class="font-black text-2xl" style="color:#f97316"><%= total.toLocaleString('ar-DZ') %> دج</span>
        </div>
        <div class="mt-4 p-3 rounded-xl text-sm text-center font-semibold text-green-400 bg-green-900/20 border border-green-800">
          💵 الدفع عند الاستلام
        </div>
        <a href="/checkout" class="block mt-4 text-center py-4 rounded-xl font-black text-lg transition-all hover:opacity-90" style="background:#00d4ff;color:#0a0f1e">
          إتمام الطلب ←
        </a>
        <a href="/products" class="block mt-3 text-center text-sm text-gray-400 hover:text-white transition-colors">
          ← متابعة التسوق
        </a>
      </div>
    </div>
  <% } %>
</div>

<footer class="border-t border-gray-800 mt-16 py-8 px-4 text-center text-gray-600 text-sm" style="background:#060b14">
  © 2026 تيك ستور — جميع الحقوق محفوظة
</footer>
</body>
</html>
